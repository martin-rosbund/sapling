{
  "name": "backend",
  "version": "1.40.876",
  "description": "",
  "author": "",
  "private": true,
  "license": "GPL-3.0",
  "mikro-orm": {
    "preferTs": true,
    "configPaths": [
      "./dist/database/mikro-orm.config.js",
      "./src/database/mikro-orm.config.ts"
    ]
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "build": "npm run clean && nest build",
    "format": "prettier --write --no-error-on-unmatched-pattern \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "npm run clean && nest start",
    "start:dev": "npm run clean && cross-env NODE_OPTIONS=--max-old-space-size=4096 nest start --watch",
    "start:debug": "npm run clean && cross-env NODE_OPTIONS=--max-old-space-size=4096 nest start --debug --watch",
    "start:prod": "npm run clean && cross-env NODE_OPTIONS=--max-old-space-size=4096 nest start",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "orm:migrate": "cross-env NODE_OPTIONS=--max-old-space-size=4096 npm run build && cross-env UPDATE_MODE=migrate node dist/update.js",
    "orm:seed": "cross-env NODE_OPTIONS=--max-old-space-size=4096 npm run build && cross-env UPDATE_MODE=seed node dist/update.js",
    "orm:deploy": "cross-env NODE_OPTIONS=--max-old-space-size=4096 npm run build && cross-env UPDATE_MODE=all node dist/update.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@googleapis/calendar": "^14.2.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@mikro-orm/core": "^7.0.13",
    "@mikro-orm/decorators": "^7.0.13",
    "@mikro-orm/migrations": "^7.0.13",
    "@mikro-orm/nestjs": "^7.0.1",
    "@mikro-orm/postgresql": "^7.0.13",
    "@mikro-orm/reflection": "^7.0.13",
    "@mikro-orm/seeder": "^7.0.13",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.4.2",
    "@oxc-node/core": "^0.1.0",
    "@types/passport-microsoft": "^2.1.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "express-rate-limit": "^8.4.1",
    "express-session": "^1.19.0",
    "gaxios": "^7.1.4",
    "googleapis": "^171.4.0",
    "googleapis-common": "^8.0.1",
    "log4js": "^6.9.1",
    "morgan": "^1.10.1",
    "openai": "^6.35.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "passport-microsoft": "^2.1.0",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "rotating-file-stream": "^3.2.9",
    "rxjs": "^7.8.2",
    "systeminformation": "^5.31.5",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@mikro-orm/cli": "^7.0.13",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
