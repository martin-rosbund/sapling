{
	"name": "sapling",
	"version": "1.40.876",
	"scripts": {
		"build:backend": "npm run build --prefix backend",
		"build:frontend": "npm run build --prefix frontend",
		"build": "npm run build:backend && npm run build:frontend",
		"debug:backend": "npm run start:debug --prefix backend",
		"debug:frontend": "npm run start:debug --prefix frontend",
		"debug": "concurrently --names \"BACKEND,FRONTEND\" \"npm:debug:backend\" \"npm:debug:frontend\"",
		"test:backend": "npm test --prefix backend -- --runInBand",
		"test:frontend": "npm run test:unit --prefix frontend -- --run",
		"test": "npm run test:backend && npm run test:frontend",
		"type-check:backend": "npm exec --prefix backend -- tsc --noEmit -p backend/tsconfig.build.json",
		"type-check:frontend": "npm run type-check --prefix frontend",
		"type-check": "npm run type-check:frontend && npm run type-check:backend",
		"verify": "npm run type-check && npm run test",
		"release:backend": "npm run start:prod --prefix backend",
		"release:frontend": "npm run start:prod --prefix frontend",
		"release": "concurrently --names \"BACKEND,FRONTEND\" \"npm:release:backend\" \"npm:release:frontend\"",
		"orm:migrate": "npm run orm:migrate --prefix backend",
		"orm:seed": "npm run orm:seed --prefix backend",
		"orm:deploy": "npm run orm:deploy --prefix backend",
		"format:backend": "npm run format --prefix backend",
		"format:frontend": "npm run format --prefix frontend",
		"format": "npm run format:backend && npm run format:frontend"
	},
	"devDependencies": {
		"concurrently": "^9.2.1"
	}
}
