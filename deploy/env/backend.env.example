# Copy to /var/www/sapling/shared/backend/.env and adjust values.
NODE_ENV=production
PORT=3000

# Required for session and authentication
SAPLING_SECRET=change-this-secret
SAPLING_FRONTEND_URL=https://example.com
SESSION_COOKIE_SECURE=true
SESSION_TRUST_PROXY=1

# Database
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=sapling
DB_PASSWORD=sapling-change-me
DB_DATABASE=sapling

# Optional Redis queue integration
REDIS_ENABLED=true
REDIS_SERVER=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# Logging
LOG_OUTPUT_PATH=./log
